{
  "name": "yasuo.js",
  "version": "0.3.1",
  "description": "The modern, fully-typed, zero-dependency Riot Games API client for TypeScript. The evolution of Twisted, with a proactive rate limiter, lazy relations and async pagination.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bunx --bun tsdown && rm -f dist/index.d.cts",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test test/unit --coverage",
    "test:unit": "bun test test/unit --coverage",
    "test:integration": "bun test test/integration",
    "test:all": "bun test",
    "check": "bun run typecheck && bun run lint && bun run test:unit",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build --strict",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "riot",
    "riot-games",
    "riot-api",
    "league-of-legends",
    "lol",
    "tft",
    "teamfight-tactics",
    "api",
    "wrapper",
    "client",
    "sdk",
    "typescript",
    "rate-limiter",
    "twisted"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justadev-afk/yasuo.js.git"
  },
  "homepage": "https://docs.yasuo.gg",
  "bugs": {
    "url": "https://github.com/justadev-afk/yasuo.js/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6 || ^7"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
